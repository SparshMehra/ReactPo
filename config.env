FLASK_APP=events_api.py
FLASK_ENV=development
FLASK_PORT=5001

# Email Configuration - Update these values to enable email sending
# See EMAIL_CONFIGURATION_GUIDE.md for detailed setup instructions
# IMPORTANT: SMTP_PASSWORD must be a Google App Password (16 characters)
# NOT your regular Gmail password! See: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=Email_Username_Here
SMTP_PASSWORD=PASSWORD_HERE
EMAIL_FROM=Email_Username_Here

FRONTEND_URL=http://localhost:3070
ADMIN_EMAIL=admin@woodlandconservation.ca
MAX_ATTENDEES_PER_BOOKING=10
BOOKING_CANCELLATION_HOURS=24

